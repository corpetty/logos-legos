    {
      "name": "logos-chat-module",
      "displayName": "Chat",
      "version": "0.3.1",
      "description": "Encrypted messaging for Logos Core",
      "author": "Logos Collective",
      "type": "service",
      "category": "Chat",
      "color": "#4CAF50",
      "dependencies": ["logos-messaging-module", "logos-capability-module"],
