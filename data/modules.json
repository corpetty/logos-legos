        {
          "name": "sendMessage",
          "description": "Send a message to a channel",
          "inputs": [
            { "name": "channel", "type": "string", "description": "Target channel name" },
            { "name": "content", "type": "string", "description": "Message content" }
          ],
          "outputs": [
            { "name": "result", "type": "MessageResult", "description": "Send result with message ID and timestamp" }
          ]
        },
        {
          "name": "getHistory",
          "description": "Retrieve message history for a channel",
          "inputs": [
            { "name": "channel", "type": "string", "description": "Channel name" },
            { "name": "limit", "type": "number", "description": "Max messages to retrieve" }
          ],
          "outputs": [
            { "name": "messages", "type": "Message[]", "description": "Array of message objects" }
          ]
        },
        {
          "name": "createChannel",
          "description": "Create a new chat channel",
          "inputs": [
            { "name": "name", "type": "string", "description": "Channel name" },
            { "name": "isPrivate", "type": "boolean", "description": "Whether channel is private" }
          ],
          "outputs": [
            { "name": "channel", "type": "Channel", "description": "Created channel object" }
          ]
        },
        {
          "name": "listChannels",
          "description": "List available channels",
          "inputs": [],
          "outputs": [
            { "name": "channels", "type": "Channel[]", "description": "Array of channel objects" }
          ]
        }
      ]
    },
